{
  "name": "distro-dev",
  "build": { "dockerfile": "Dockerfile", "context": ".." },
  "runArgs": ["--privileged"],
  "mounts": [
    "source=distro-dev-extensions,target=/root/.vscode-server/extensions,type=volume",
    "source=distro-dev-server-data,target=/root/.vscode-server/data/Machine,type=volume"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "ms-vscode.cpptools-extension-pack",
        "ms-vscode.makefile-tools"
      ]
    }
  }
}
